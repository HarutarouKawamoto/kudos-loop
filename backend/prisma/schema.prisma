datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// --- 以下、ER図を基にモデル定義 ---

model Team {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

model User {
  id            Int                @id @default(autoincrement())
  email         String             @unique
  name          String
  password      String
  teamId        Int
  team          Team               @relation(fields: [teamId], references: [id])
  sentKudos     KudosTransaction[] @relation("Sender")
  receivedKudos KudosTransaction[] @relation("Receiver")
}

model Badge {
  id          Int                @id @default(autoincrement())
  name        String
  description String
  iconUrl     String
  kudos       KudosTransaction[]
}

model KudosTransaction {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  badgeId    Int
  message    String?
  createdAt  DateTime @default(now())

  sender   User  @relation("Sender", fields: [senderId], references: [id])
  receiver User  @relation("Receiver", fields: [receiverId], references: [id])
  badge    Badge @relation(fields: [badgeId], references: [id])
}